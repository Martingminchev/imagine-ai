# ── Database ──────────────────────────────────────────────────
MONGO=mongodb://localhost:27017/orchestrator

# ── Server ────────────────────────────────────────────────────
PORT=4447

# ── Embedding Provider ────────────────────────────────────────
# ollama (local, default) or openai (cloud)
EMBED_PROVIDER=ollama

# Ollama (default — no key needed)
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text

# OpenAI (optional, when EMBED_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_EMBED_MODEL=text-embedding-3-large
# OPENAI_EMBED_DIMS=1536

# ── LLM Provider ─────────────────────────────────────────────
# ollama (local, default) | gemini | moonshot
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3

# Google Gemini (optional)
# GEMINI_API_KEY=

# Moonshot / Kimi (optional)
# MOONSHOT_API_KEY=

# ── Projects (optional) ───────────────────────────────────────
# Per-project file awareness is configured via the API:
#   POST /api/projects { conversationId, projectRoot }
#
# Each project conversation gets its own isolated memory context.
# Files under projectRoot are embedded and surfaced when relevant.
# The orchestrator can read (never write) files under project paths.
#
# Legacy: set PROJECT_ROOT to use a single global project directory.
# PROJECT_ROOT=/path/to/your/project

# ── Autonomy ─────────────────────────────────────────────────
# The autonomy system generates thoughts between interactions.
# These settings are defaults — can be overridden per conversation via API.
# AUTONOMY_ENABLED=true
# REAPPEARANCE_MIN=5
# REAPPEARANCE_MAX=20

# ── Meta-Orchestrator ────────────────────────────────────────
# Cross-project learning loop. Periodically reviews lessons from
# all projects and synthesizes generalized insights when patterns
# emerge across 2+ projects. Interval is in milliseconds.
# META_TICK_INTERVAL=300000
