# ── Database ──────────────────────────────────────────────────
MONGO=mongodb://localhost:27017/imagine

# ── Server ────────────────────────────────────────────────────
PORT=4447

# ── Ollama (local LLM + embeddings) ─────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
EMBED_MODEL=nomic-embed-text

# ── LLM Provider ─────────────────────────────────────────────
# ollama (local, default) | gemini | moonshot
LLM_PROVIDER=ollama

# ── Google Gemini (optional) ─────────────────────────────────
# GEMINI_API_KEY=

# ── Moonshot / Kimi (optional) ───────────────────────────────
# MOONSHOT_API_KEY=
